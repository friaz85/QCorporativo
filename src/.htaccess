RewriteEngine On
# If an existing asset or directory is requested go to it as it is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If any other extension is requested and it is not a directory, go to index.html
RewriteRule ^ /corporativo/index.html [L]
